# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Gmail address that sends AND receives contact form emails
GMAIL_USER=mnsai.official@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# How to get one:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (must be ON)
#   2. Search "App passwords" in the search bar
#   3. Create a new app password → name it "MNSAI Website"
#   4. Copy the 16-character password and paste it below
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
